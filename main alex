import java.util.ArrayList;
import java.util.Scanner;

public class Main {

    public static void main(String[] args) {

        Scanner leer = new Scanner(System.in);

        ArrayList<Paciente> pacientes = new ArrayList<>();
        int opcion = 0;

        while (opcion != 5) {

            System.out.println("Sistema de atencion medica");
            System.out.println("1. Registrar consulta");
            System.out.println("2. Buscar paciente");
            System.out.println("3. Ver pacientes registrados");
            System.out.println("4. Informacion del sistema");
            System.out.println("5. Salir");
            System.out.print("Seleccione una opcion: ");

            opcion = leer.nextInt();
            leer.nextLine();

            if (opcion == 1) {

                System.out.print("Nombre: ");
                String nombre = leer.nextLine();

                System.out.print("RUT: ");
                String rut = leer.nextLine();

                System.out.print("Edad: ");
                int edad = leer.nextInt();
                leer.nextLine();

                System.out.print("Comuna: ");
                String comuna = leer.nextLine();

                System.out.print("Diagnostico: ");
                String diagnostico = leer.nextLine();

                Paciente nuevo = new Paciente(
                        nombre,
                        rut,
                        edad,
                        comuna,
                        diagnostico
                );

                pacientes.add(nuevo);
                System.out.println("Paciente registrado correctamente.");

            } else if (opcion == 2) {
                if (pacientes.isEmpty()) {
                    System.out.println("No hay pacientes registrados.");
                } else {
                    System.out.print("Ingrese RUT a buscar: ");
                    String rutBuscar = leer.nextLine();
                    boolean encontrado = false;
                    for (int i = 0; i < pacientes.size(); i++) {
                        if (pacientes.get(i).rut.equalsIgnoreCase(rutBuscar)) {

                            System.out.println("\n=== PACIENTE ENCONTRADO ===");
                            System.out.println("Nombre: " + pacientes.get(i).nombre);
                            System.out.println("RUT: " + pacientes.get(i).rut);
                            System.out.println("Edad: " + pacientes.get(i).edad);
                            System.out.println("Comuna: " + pacientes.get(i).comuna);
                            System.out.println("Diagnostico: " + pacientes.get(i).diagnostico);

                            encontrado = true;
                        }
                    }
                    if (!encontrado) {
                        System.out.println("Paciente no encontrado.");
                    }
                }
            } else if (opcion == 3) {
                if (pacientes.isEmpty()) {
                    System.out.println("No existen registros.");
                } else {
                    System.out.println("\n=== LISTA DE PACIENTES ===");
                    for (int i = 0; i < pacientes.size(); i++) {
                        System.out.println(
                                (i + 1) + ". "
                                + pacientes.get(i).nombre
                                + " - "
                                + pacientes.get(i).rut
                        );
                    }
                }

            } else if (opcion == 4) {
                System.out.println("Sistema orientado al registro y consulta de pacientes.");
                System.out.println("Permite almacenar informacion basica y consultas medicas.");
            } else if (opcion == 5) {
                System.out.println("Saliendo del sistema...");
            } else {
              System.out.println("Opcion invalida.");

            }
        }
        leer.close();
    }
}
